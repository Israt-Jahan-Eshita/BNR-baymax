# OpenAI Integration
OPENAI_API_KEY=your-openai-api-key

# Backend Server Configuration
PORT=8080

# CORS Configuration
# Comma-separated list of allowed origins. Example: https://bnr-baymax-web.onrender.com
ALLOWED_ORIGINS=

# Database Configuration (Supabase PostgreSQL)
# IMPORTANT: Use the Session Pooler connection on port 5432!
# Format: jdbc:postgresql://<SUPABASE_SESSION_POOLER_HOST>:5432/postgres?sslmode=require
DATABASE_URL=jdbc:postgresql://localhost:5433/baymax
DATABASE_USERNAME=your-supabase-username
DATABASE_PASSWORD=your-supabase-password

# Frontend Configuration
# URL of the deployed backend. Set this BEFORE building the frontend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
